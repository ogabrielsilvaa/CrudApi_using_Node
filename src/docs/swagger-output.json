{
  "swagger": "2.0",
  "info": {
    "version": "1.0.0",
    "title": "REST API",
    "description": "Documentação das rotas da minha API feita em Node."
  },
  "host": "localhost:3000",
  "basePath": "/",
  "schemes": [
    "http"
  ],
  "securityDefinitions": {
    "bearerAuth": {
      "type": "apiKey",
      "name": "Authorization",
      "in": "header",
      "description": "Insira o token JWT com o prefixo Bearer. Exemplo: Bearer eyJhbGci..."
    }
  },
  "paths": {
    "/auth/login": {
      "post": {
        "summary": "Autentica um usuário e retorna um token JWT",
        "tags": ["Autenticação"],
        "parameters": [
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": {
              "type": "object",
              "required": ["email", "password"],
              "properties": {
                "email": {
                  "type": "string",
                  "example": "arrascaeta@flamengo.com"
                },
                "password": {
                  "type": "string",
                  "example": "123"
                }
              }
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Login realizado com sucesso",
            "schema": {
              "type": "object",
              "properties": {
                "tokenType": { "type": "string", "example": "Bearer" },
                "accessToken": { "type": "string", "example": "eyJhbGciOiJIUzI1NiIsInR5cCI..." },
                "expiresIn": { "type": "string", "example": "1d" }
              }
            }
          },
          "400": { "description": "Dados incompletos (E-mail ou senha ausentes)" },
          "401": { "description": "Credenciais inválidas" },
          "500": { "description": "Erro interno no servidor" }
        }
      }
    },
    "/api/v1/users/": {
      "get": {
        "summary": "Lista todos os usuários",
        "tags": ["Usuários"],
        "security": [ { "bearerAuth": [] } ],
        "responses": {
          "200": { "description": "Lista de usuários retornada com sucesso" },
          "401": { "description": "Não autorizado" },
          "403": { "description": "Proibido" }
        }
      },
      "post": {
        "summary": "Cadastra um novo usuário",
        "tags": ["Usuários"],
        "parameters": [
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": {
              "type": "object",
              "required": ["nome", "email", "senha"],
              "properties": {
                "nome": { "type": "string", "example": "João" },
                "email": { "type": "string", "example": "joao@email.com" },
                "senha": { "type": "string", "example": "123" },
                "dataNascimento": { "type": "string", "format": "date", "example": "2036-03-18" },
                "rg": { "type": "string", "example": "21312123112" },
                "cpf": { "type": "string", "example": "21312123112" },
                "nomeMae": { "type": "string", "example": "nome da sua mae" }
              }
            }
          }
        ],
        "responses": {
          "201": { "description": "Usuário criado com sucesso" },
          "400": { "description": "Dados inválidos" }
        }
      }
    },
    "/api/v1/users/{id}": {
      "get": {
        "summary": "Busca um usuário por ID",
        "tags": ["Usuários"],
        "security": [ { "bearerAuth": [] } ],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "type": "integer" }
        ],
        "responses": {
          "200": { "description": "Usuário encontrado" },
          "401": { "description": "Não autorizado" },
          "404": { "description": "Usuário não encontrado" }
        }
      },
      "put": {
        "summary": "Atualiza um usuário existente",
        "tags": ["Usuários"],
        "security": [ { "bearerAuth": [] } ],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "type": "integer" },
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": {
              "type": "object",
              "properties": {
                "nome": { "type": "string", "example": "João Atualizado" },
                "email": { "type": "string", "example": "joao_novo@email.com" }
              }
            }
          }
        ],
        "responses": {
          "200": { "description": "Usuário atualizado com sucesso" },
          "401": { "description": "Não autorizado" },
          "404": { "description": "Usuário não encontrado" }
        }
      },
      "delete": {
        "summary": "Remove um usuário",
        "tags": ["Usuários"],
        "security": [ { "bearerAuth": [] } ],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "type": "integer" }
        ],
        "responses": {
          "204": { "description": "Usuário removido com sucesso" },
          "401": { "description": "Não autorizado" },
          "403": { "description": "Proibido (Apenas administradores)" },
          "404": { "description": "Usuário não encontrado" }
        }
      }
    },
    "/api/v1/contatos/": {
      "get": {
        "summary": "Lista todos os contatos",
        "tags": ["Contatos"],
        "security": [ { "bearerAuth": [] } ],
        "responses": {
          "200": { "description": "Lista de contatos retornada com sucesso" },
          "401": { "description": "Não autorizado" }
        }
      },
      "post": {
        "summary": "Cadastra um novo contato",
        "tags": ["Contatos"],
        "security": [ { "bearerAuth": [] } ],
        "parameters": [
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": {
              "type": "object",
              "required": ["idUsuario", "numeroTelefone"],
              "properties": {
                "idUsuario": { "type": "integer", "example": 1 },
                "numeroTelefone": { "type": "string", "example": "11999999999" }
              }
            }
          }
        ],
        "responses": {
          "201": { "description": "Contato criado com sucesso" },
          "400": { "description": "Dados inválidos" },
          "401": { "description": "Não autorizado" }
        }
      }
    },
    "/api/v1/contatos/{id}": {
      "get": {
        "summary": "Busca um contato por ID",
        "tags": ["Contatos"],
        "security": [ { "bearerAuth": [] } ],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "type": "integer" }
        ],
        "responses": {
          "200": { "description": "Contato encontrado" },
          "401": { "description": "Não autorizado" },
          "404": { "description": "Contato não encontrado" }
        }
      },
      "put": {
        "summary": "Atualiza um contato existente",
        "tags": ["Contatos"],
        "security": [ { "bearerAuth": [] } ],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "type": "integer" },
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": {
              "type": "object",
              "properties": {
                "numeroTelefone": { "type": "string", "example": "11888888888" }
              }
            }
          }
        ],
        "responses": {
          "200": { "description": "Contato atualizado com sucesso" },
          "401": { "description": "Não autorizado" },
          "404": { "description": "Contato não encontrado" }
        }
      },
      "delete": {
        "summary": "Remove um contato",
        "tags": ["Contatos"],
        "security": [ { "bearerAuth": [] } ],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "type": "integer" }
        ],
        "responses": {
          "204": { "description": "Contato removido com sucesso" },
          "401": { "description": "Não autorizado" },
          "403": { "description": "Proibido (Apenas administradores)" },
          "404": { "description": "Contato não encontrado" }
        }
      }
    },
    "/api/v1/enderecos/": {
      "get": {
        "summary": "Lista todos os endereços",
        "tags": ["Endereços"],
        "security": [ { "bearerAuth": [] } ],
        "responses": {
          "200": { "description": "Lista de endereços retornada com sucesso" },
          "401": { "description": "Não autorizado" }
        }
      },
      "post": {
        "summary": "Cadastra um novo endereço",
        "tags": ["Endereços"],
        "security": [ { "bearerAuth": [] } ],
        "parameters": [
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": {
              "type": "object",
              "required": ["idUsuario", "cep", "rua", "numero", "complemento", "bairro", "cidade", "estado"],
              "properties": {
                "idUsuario": { 
                  "type": "integer", 
                  "description": "ID do usuário ao qual este endereço pertence.",
                  "example": 1 
                },
                "cep": { "type": "string", "example": "20000-000" },
                "rua": { "type": "string", "example": "Avenida Presidente Vargas" },
                "numero": { "type": "string", "example": "1" },
                "complemento": { "type": "string", "example": "Apto 101" },
                "bairro": { "type": "string", "example": "Centro" },
                "cidade": { "type": "string", "example": "Rio de Janeiro" },
                "estado": { "type": "string", "example": "RJ" }
              }
            }
          }
        ],
        "responses": {
          "201": { "description": "Endereço criado com sucesso" },
          "400": { "description": "Dados inválidos" },
          "401": { "description": "Não autorizado" }
        }
      }
    },
    "/api/v1/enderecos/{id}": {
      "get": {
        "summary": "Busca um endereço por ID",
        "tags": ["Endereços"],
        "security": [ { "bearerAuth": [] } ],
        "parameters": [
          { 
            "name": "id", 
            "in": "path", 
            "required": true, 
            "type": "integer",
            "description": "ID exclusivo do endereço."
          }
        ],
        "responses": {
          "200": { "description": "Endereço encontrado" },
          "401": { "description": "Não autorizado" },
          "404": { "description": "Endereço não encontrado" }
        }
      },
      "put": {
        "summary": "Atualiza um endereço existente",
        "tags": ["Endereços"],
        "security": [ { "bearerAuth": [] } ],
        "parameters": [
          { 
            "name": "id", 
            "in": "path", 
            "required": true, 
            "type": "integer",
            "description": "ID exclusivo do endereço que será atualizado."
          },
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": {
              "type": "object",
              "properties": {
                "cep": { "type": "string", "example": "22000-000" },
                "rua": { "type": "string", "example": "Avenida Atlântica" },
                "complemento": { "type": "string", "example": "Cobertura 01" },
                "bairro": { "type": "string", "example": "Copacabana" },
                "cidade": { "type": "string", "example": "Rio de Janeiro" },
                "estado": { "type": "string", "example": "RJ" }
              }
            }
          }
        ],
        "responses": {
          "200": { "description": "Endereço atualizado com sucesso" },
          "401": { "description": "Não autorizado" },
          "404": { "description": "Endereço não encontrado" }
        }
      },
      "delete": {
        "summary": "Remove um endereço",
        "tags": ["Endereços"],
        "security": [ { "bearerAuth": [] } ],
        "parameters": [
          { 
            "name": "id", 
            "in": "path", 
            "required": true, 
            "type": "integer",
            "description": "ID exclusivo do endereço que será removido."
          }
        ],
        "responses": {
          "204": { "description": "Endereço removido com sucesso" },
          "401": { "description": "Não autorizado" },
          "403": { "description": "Proibido (Apenas administradores)" },
          "404": { "description": "Endereço não encontrado" }
        }
      }
    }
  },
  "definitions": {
    "openapi": {
      "type": "string",
      "example": "3.0.0"
    },
    "info": {
      "type": "object",
      "properties": {
        "title": {
          "type": "string",
          "example": "API de Usuários, Contatos e Endereços"
        },
        "version": {
          "type": "string",
          "example": "1.0.0"
        },
        "description": {
          "type": "string",
          "example": "Documentação da API desenvolvida com Express e Sequelize"
        }
      }
    },
    "servers": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "url": {
            "type": "string",
            "example": "http://localhost:3000"
          },
          "description": {
            "type": "string",
            "example": "Servidor local"
          }
        }
      }
    },
    "components": {
      "type": "object",
      "properties": {
        "securitySchemes": {
          "type": "object",
          "properties": {
            "bearerAuth": {
              "type": "object",
              "properties": {
                "type": {
                  "type": "string",
                  "example": "http"
                },
                "scheme": {
                  "type": "string",
                  "example": "bearer"
                },
                "bearerFormat": {
                  "type": "string",
                  "example": "JWT"
                }
              }
            }
          }
        }
      }
    }
  },
  "apis": [
    "./src/routes/*.js"
  ]
}